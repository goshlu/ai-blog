// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Post {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  date      String
  excerpt   String?
  content   String
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  title     String
  date      String
  content   String
  mood      String?
  weather   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Thought {
  id        String   @id @default(uuid())
  content   String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
