# ============================================
# 必需环境变量
# ============================================

# OpenAI API 密钥（必需）
# 用于 AI 内容生成、智能摘要和翻译功能
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# 管理员密码（必需）
# 用于登录 /admin 管理后台
ADMIN_PASSWORD=your-secure-password-here

# ============================================
# 数据库配置（二选一）
# ============================================

# 选项 1: 本地 SQLite 数据库（开发环境推荐）
DATABASE_URL=file:./prisma/dev.db

# 选项 2: Turso 云数据库（生产环境推荐）
# 注释掉上面的 DATABASE_URL，启用下面两行
# 获取地址: https://turso.tech/
# TURSO_DATABASE_URL=libsql://your-database-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ============================================
# 可选环境变量
# ============================================

# 网站公开 URL（可选）
# 用于 RSS feed、sitemap 和社交分享链接
# 开发环境可以使用 http://localhost:3000
# 生产环境应设置为实际域名
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 管理员会话加密密钥（可选）
# 如不设置，将使用 ADMIN_PASSWORD 作为密钥
# ADMIN_SESSION_SECRET=your-random-secret-string

# 订阅通知 Webhook URL（可选）
# 如果需要邮件订阅通知功能，配置此 Webhook
# SUBSCRIPTION_WEBHOOK_URL=https://your-webhook-service.com/notify
